{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-community/php@0.4.3"
    }
  },
  "rewrites": [
    {
      "source": "/download_vcf.php",
      "destination": "/api/download_vcf.php"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
